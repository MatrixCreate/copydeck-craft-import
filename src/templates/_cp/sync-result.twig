{% extends '_layouts/cp' %}

{% set title = 'Sync Report' %}

{% set crumbs = [
    { label: 'Copydeck', url: url('copydeck-importer') },
] %}

{% block actionButton %}
    <a class="btn submit" href="{{ url('copydeck-importer/sync') }}">
        {{ 'Sync Again'|t('copydeck-importer') }}
    </a>
{% endblock %}

{# Recursive macro for rendering page tree rows #}
{% macro pageRows(slugs, slugToPage, childrenOf, depth) %}
    {% for slug in slugs %}
        {% set page = slugToPage[slug] ?? null %}
        {% if page %}
            {% set indent = depth * 24 %}
            {% set isLocked = 'Skipped — entry is locked.' in (page.warnings ?? []) %}
            <tr>
                <td style="padding-left:{{ 12 + indent }}px;">
                    {% if depth > 0 %}
                        <span style="color:var(--hairline-color); margin-right:4px;">{% for i in 1..depth %}&mdash;{% endfor %}</span>
                    {% endif %}
                    <strong>{{ page.title ?? page.slug ?? '?' }}</strong>
                    {% set otherWarnings = (page.warnings ?? [])|filter(w => w != 'Skipped — entry is locked.') %}
                    {% if isLocked %}
                        <span class="light" style="margin-left:6px;">— Skipped (locked)</span>
                    {% endif %}
                    {% if page.error ?? null %}
                        <span style="color:var(--error-color); margin-left:6px;">— {{ page.error }}</span>
                    {% endif %}
                    {% for warning in otherWarnings %}
                        <span style="color:var(--warning-color); margin-left:6px;">— {{ warning }}</span>
                    {% endfor %}
                </td>
                <td><code style="font-size:12px;">{{ page.slug ?? '?' }}</code></td>
                <td>
                    {% if 'Skipped — entry is locked.' in (page.warnings ?? []) %}
                        <span class="status disabled"></span> Locked
                    {% elseif page.success ?? false %}
                        {% if page.entryFound ?? false %}
                            <span class="status blue"></span> Updated
                        {% else %}
                            <span class="status green"></span> Created
                        {% endif %}
                    {% else %}
                        <span class="status red"></span> Failed
                    {% endif %}
                </td>
                <td class="thin" style="white-space:nowrap;">
                    {% if page.entryId ?? null %}
                        {% set pageEntry = craft.entries.id(page.entryId).status(null).one() %}
                        {% if pageEntry %}
                            <a href="{{ pageEntry.cpEditUrl }}" class="btn small" title="Edit in CP">
                                {{ 'Edit'|t('copydeck-importer') }}
                            </a>
                            {% if pageEntry.url %}
                                <a href="{{ pageEntry.url }}" class="btn small" target="_blank" title="View on site">
                                    {{ 'View'|t('copydeck-importer') }}
                                </a>
                            {% endif %}
                        {% endif %}
                    {% endif %}
                </td>
            </tr>


            {# Recurse into children #}
            {% set children = childrenOf[slug] ?? [] %}
            {% if children|length %}
                {{ _self.pageRows(children, slugToPage, childrenOf, depth + 1) }}
            {% endif %}
        {% endif %}
    {% endfor %}
{% endmacro %}

{% block content %}

    {# Overall status banner #}
    {% if run.status == 'success' %}
        <div class="pane" style="background:var(--green-050); border:1px solid var(--green-300); margin-bottom:24px; padding:16px; border-radius:8px;">
            <span class="status green"></span>
            <strong>{{ 'Sync completed successfully'|t('copydeck-importer') }}</strong>
        </div>
    {% elseif run.status == 'warnings' %}
        <div class="pane" style="background:var(--yellow-050); border:1px solid var(--yellow-300); margin-bottom:24px; padding:16px; border-radius:8px;">
            <span class="status orange"></span>
            <strong>{{ 'Sync completed with warnings'|t('copydeck-importer') }}</strong>
        </div>
    {% else %}
        <div class="pane" style="background:var(--red-050); border:1px solid var(--red-300); margin-bottom:24px; padding:16px; border-radius:8px;">
            <span class="status red"></span>
            <strong>{{ 'Sync completed with errors'|t('copydeck-importer') }}</strong>
        </div>
    {% endif %}

    {# Summary line #}
    {% set pages = run.result ?? [] %}
    {% set totalImages = 0 %}
    {% set reusedImages = 0 %}
    {% set totalWarnings = 0 %}
    {% for page in pages %}
        {% for img in page.images ?? [] %}
            {% set totalImages = totalImages + 1 %}
            {% if img.reused %}
                {% set reusedImages = reusedImages + 1 %}
            {% endif %}
        {% endfor %}
        {% set totalWarnings = totalWarnings + (page.warnings ?? [])|length %}
    {% endfor %}

    <div style="margin-bottom:24px; font-size:14px; color:var(--text-color);">
        <strong>{{ pages|length }}</strong> {{ pages|length == 1 ? 'page' : 'pages' }} imported
        &middot; <strong>{{ totalImages - reusedImages }}</strong> images downloaded
        &middot; <strong>{{ reusedImages }}</strong> images reused
        {% if totalWarnings > 0 %}
            &middot; <strong style="color:var(--warning-color);">{{ totalWarnings }}</strong> {{ totalWarnings == 1 ? 'warning' : 'warnings' }}
        {% endif %}
    </div>

    {# Build tree lookup maps from parentSlug #}
    {% set slugToPage = {} %}
    {% set childrenOf = {} %}
    {% set rootSlugs = [] %}

    {% for page in pages %}
        {% set slug = page.slug ?? '' %}
        {% set parentSlug = page.parentSlug ?? null %}
        {% set slugToPage = slugToPage|merge({ (slug): page }) %}

        {% if parentSlug and parentSlug != '' %}
            {% set existing = childrenOf[parentSlug] ?? [] %}
            {% set childrenOf = childrenOf|merge({ (parentSlug): existing|merge([slug]) }) %}
        {% else %}
            {% set rootSlugs = rootSlugs|merge([slug]) %}
        {% endif %}
    {% endfor %}

    {# Hierarchical page tree #}
    <div class="pane" style="border-radius:8px;">
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ 'Page'|t('copydeck-importer') }}</th>
                    <th>{{ 'Slug'|t('copydeck-importer') }}</th>
                    <th>{{ 'Status'|t('copydeck-importer') }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {{ _self.pageRows(rootSlugs, slugToPage, childrenOf, 0) }}
            </tbody>
        </table>
    </div>

{% endblock %}
