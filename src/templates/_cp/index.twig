{% extends '_layouts/cp' %}

{% set title = 'Copydeck' %}

{% block content %}

    <div style="max-width:680px; margin:40px auto;">

        {# Primary action — Sync from Copydeck #}
        <div class="pane" style="padding:32px; margin-bottom:24px; border-radius:8px;">
            <h2 style="margin-top:0; margin-bottom:8px; font-size:20px;">
                {{ 'Sync from Copydeck'|t('copydeck-importer') }}
            </h2>
            <p class="light" style="margin-bottom:20px;">
                {{ 'Pull the latest content directly via API.'|t('copydeck-importer') }}
            </p>
            {% if apiConfigured %}
                <a href="{{ url('copydeck-importer/sync') }}" class="btn submit">
                    {{ 'Sync Now'|t('copydeck-importer') }}
                </a>
            {% else %}
                <a href="{{ cpUrl('settings/plugins/copydeck-importer') }}" class="btn">
                    {{ 'Configure API Access'|t('copydeck-importer') }}
                </a>
            {% endif %}
        </div>

        {# Secondary action — Import JSON file #}
        <div class="pane" style="padding:24px; margin-bottom:24px; border-radius:8px;">
            <h3 style="margin-top:0; margin-bottom:6px; font-size:16px;">
                {{ 'Import JSON File'|t('copydeck-importer') }}
            </h3>
            <p class="light" style="margin-bottom:16px; font-size:14px;">
                {{ 'Upload an export file manually.'|t('copydeck-importer') }}
            </p>
            <a href="{{ url('copydeck-importer/upload') }}" class="btn">
                {{ 'Upload File'|t('copydeck-importer') }}
            </a>
        </div>

        {# History link #}
        <div style="text-align:center;">
            <a href="{{ url('copydeck-importer/history') }}" class="go">
                {{ 'View import history'|t('copydeck-importer') }}
            </a>
        </div>

    </div>

{% endblock %}
